generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  HEAD
  TEAM_LEAD
  BUYER
  BUYER_ASSISTANT
  DESIGNER
  TECHNICAL_SPECIALIST
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  WAITING_APPROVAL
  REVISION
  DONE
  CLOSED
  CANCELLED
}

enum TaskType {
  LANDING
  PRELANDING
  CREATIVES
  BANNER
  VIDEO
  PIXEL_SETUP
  CLOAKING
  DOMAIN_SETUP
  HOSTING_SETUP
  OTHER
}

enum ExecutorType {
  DESIGNER
  TECHNICAL_SPECIALIST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique @map("telegram_id")
  username   String?
  firstName  String   @map("first_name")
  lastName   String?  @map("last_name")
  role       Role
  teamId     Int?     @map("team_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  team          Team?         @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeam       Team?         @relation("TeamLead")
  createdTasks  Task[]        @relation("TaskCreator")
  executedTasks Task[]        @relation("TaskExecutor")
  taskHistory   TaskHistory[]
  messages      TaskMessage[]
  invitesSent   Invite[]      @relation("InviteSender")
  ratings       Rating[]

  @@map("users")
}

model Team {
  id         Int      @id @default(autoincrement())
  name       String
  teamLeadId Int      @unique @map("team_lead_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  teamLead User   @relation("TeamLead", fields: [teamLeadId], references: [id])
  members  User[] @relation("TeamMembers")
  tasks    Task[]

  @@map("teams")
}

model Task {
  id           Int          @id @default(autoincrement())
  title        String
  description  String?
  type         TaskType
  executorType ExecutorType @map("executor_type")
  priority     Priority     @default(MEDIUM)
  status       TaskStatus   @default(OPEN)
  creatorId    Int          @map("creator_id")
  executorId   Int?         @map("executor_id")
  teamId       Int?         @map("team_id")
  deadline     DateTime?
  files        String[]     @default([])
  links        String[]     @default([])
  chatId       BigInt?      @map("chat_id")
  messageId    Int?         @map("message_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  closedAt     DateTime?    @map("closed_at")

  creator  User          @relation("TaskCreator", fields: [creatorId], references: [id])
  executor User?         @relation("TaskExecutor", fields: [executorId], references: [id])
  team     Team?         @relation(fields: [teamId], references: [id])
  tags     TaskTag[]
  history  TaskHistory[]
  messages TaskMessage[]

  @@map("tasks")
}

model TaskTag {
  id     Int    @id @default(autoincrement())
  taskId Int    @map("task_id")
  tag    String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_tags")
}

model TaskHistory {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  action    String
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_history")
}

model TaskMessage {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  userId    Int      @map("user_id")
  message   String
  fileUrl   String?  @map("file_url")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_messages")
}

model Invite {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  role        Role
  teamId      Int?      @map("team_id")
  createdById Int       @map("created_by_id")
  usedById    Int?      @map("used_by_id")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  createdBy User @relation("InviteSender", fields: [createdById], references: [id])

  @@map("invites")
}

model Rating {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  period         String
  totalTasks     Int      @default(0) @map("total_tasks")
  completedTasks Int      @default(0) @map("completed_tasks")
  cancelledTasks Int      @default(0) @map("cancelled_tasks")
  revisionCount  Int      @default(0) @map("revision_count")
  overdueCount   Int      @default(0) @map("overdue_count")
  avgTimeHours   Float?   @map("avg_time_hours")
  score          Float    @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, period])
  @@map("ratings")
}
