{
  "name": "tg-task-manager",
  "version": "1.0.0",
  "description": "Telegram Task Manager for Arbitrage Team",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "echo STARTING_BOT && ls dist/ && node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "grammy": "^1.26.0",
    "@grammyjs/conversations": "1.2.0",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/storage-redis": "^2.4.2",
    "@prisma/client": "^5.22.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
